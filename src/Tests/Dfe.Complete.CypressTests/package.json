{
  "name": "complete.cypresstests",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "cy:open": "cypress open --browser edge",
    "cy:run": "npm run clean:reports && cypress run --browser edge",
    "cy:zap": "npm run clean:reports && cypress run --browser electron --spec 'cypress/e2e/user-capabilities/**/*'",
    "cy:notify": "cypress-slack-reporter",
    "clean:reports": "rm -rf cypress/reports/mocha/*.json",
    "combine:reports": "mochawesome-merge  cypress/reports/mocha/*.json> mochareports/report.json",
    "create:html:report": "marge  mochareports/report.json -f report -o mochareports",
    "generate:html:report": "npm run combine:reports && npm run create:html:report",
    "lint": "eslint .",
    "prettier:check": "prettier . --check",
    "prettier:write": "prettier . --write",
    "format": "npm run prettier:write && npm run lint",
    "format:check": "npm run prettier:check && npm run lint",
    "cy:cache": "cypress cache clear"
  },
  "keywords": [
    "e2e",
    "regression",
    "automation"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@cypress/webpack-preprocessor": "7.0.2",
    "@eslint/js": "10.0.1",
    "@types/node": "25.5.0",
    "axe-core": "4.11.1",
    "buffer": "6.0.3",
    "csv-stringify": "6.7.0",
    "cypress": "15.12.0",
    "cypress-axe": "1.7.0",
    "cypress-localstorage-commands": "2.3.0",
    "cypress-multi-reporters": "2.0.5",
    "cypress-slack-reporter": "1.5.4",
    "eslint": "10.0.3",
    "eslint-plugin-cypress": "6.2.0",
    "globals": "17.4.0",
    "mocha": "11.7.5",
    "mochawesome": "7.1.4",
    "mochawesome-merge": "5.1.1",
    "mochawesome-report-generator": "6.3.2",
    "prettier": "3.8.3",
    "process": "0.11.10",
    "stream-browserify": "3.0.0",
    "ts-loader": "9.5.4",
    "typescript": "5.9.3",
    "typescript-eslint": "8.57.1",
    "util": "0.12.5",
    "webpack": "5.105.4",
    "zaproxy": "2.0.0-rc.7"
  }
}
